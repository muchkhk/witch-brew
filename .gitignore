# ── OS ──
.DS_Store

# ── Claude Code ──
# .claude 配下のローカル設定・セッションログ・履歴・todo 等は追跡しない
# （公開リポジトリなので、機微を含みうる作業ログを誤ってコミットしないため）。
# 共有すべき許可リスト settings.json だけは追跡対象に残す。
.claude/*
!.claude/settings.json

# ── Local test/runtime artifacts ──
node_modules/
.firebase-config/
*-debug.log
__pycache__/
# シミュレータの実行進捗ログ（一時的な標準エラー出力。結果はresults.md/.jsonへ）
sim/**/run.log
sim/**/k1_run.log
sim/**/run_process2.log
