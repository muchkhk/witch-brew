{
  "rules": {
    ".read": false,
    ".write": false,
    "transmit4pRoomsV0": {
      "$code": {
        "meta": {
          ".read": "auth != null && data.exists()",
          ".write": "auth != null && $code.matches(/^[A-HJ-NP-Z2-9]{6}$/) && ((!data.exists() && newData.child('hostUid').val() === auth.uid && newData.child('phase').val() === 'lobby') || (data.exists() && data.child('hostUid').val() === auth.uid && newData.child('hostUid').val() === auth.uid))",
          ".validate": "newData.hasChildren(['hostUid','phase','mode','drainSpeed','hintDrainToggle','version','createdAt']) && (newData.child('mode').val() === 'human4' || newData.child('mode').val() === 'npc2') && (newData.child('drainSpeed').val() === 'off' || newData.child('drainSpeed').val() === 'slow' || newData.child('drainSpeed').val() === 'standard' || newData.child('drainSpeed').val() === 'fast') && (newData.child('hintDrainToggle').val() === 'off' || newData.child('hintDrainToggle').val() === 'equal')",
          "hostUid": { ".validate": "newData.isString() && newData.val().length >= 6 && newData.val().length <= 128" },
          "phase": { ".validate": "newData.isString() && (newData.val() === 'lobby' || newData.val() === 'setup' || newData.val() === 'playing' || newData.val() === 'ended')" },
          "mode": { ".validate": "newData.isString()" },
          "drainSpeed": { ".validate": "newData.isString()" },
          "hintDrainToggle": { ".validate": "newData.isString()" },
          "version": { ".validate": "newData.isString()" },
          "createdAt": { ".validate": "newData.isNumber() && newData.val() > 0" },
          "$other": { ".validate": false }
        },
        "seats": {
          ".read": "auth != null && root.child('transmit4pRoomsV0').child($code).child('meta').exists()",
          "$seat": {
            ".write": "auth != null && $seat.matches(/^[0-3]$/) && ((!data.exists() && root.child('transmit4pRoomsV0').child($code).child('meta').child('phase').val() === 'lobby' && newData.child('uid').val() === auth.uid && ($seat === '0' || root.child('transmit4pRoomsV0').child($code).child('seats').child('0').child('uid').val() !== auth.uid) && ($seat === '1' || root.child('transmit4pRoomsV0').child($code).child('seats').child('1').child('uid').val() !== auth.uid) && ($seat === '2' || root.child('transmit4pRoomsV0').child($code).child('seats').child('2').child('uid').val() !== auth.uid) && ($seat === '3' || root.child('transmit4pRoomsV0').child($code).child('seats').child('3').child('uid').val() !== auth.uid)) || (data.exists() && data.child('uid').val() === auth.uid && newData.child('uid').val() === auth.uid) || (root.child('transmit4pRoomsV0').child($code).child('meta').child('hostUid').val() === auth.uid && newData.child('isNpc').val() === true))",
            ".validate": "newData.hasChildren(['uid','name','lastSeen','isNpc'])",
            "uid": { ".validate": "newData.isString() && (newData.val() === auth.uid || newData.parent().child('isNpc').val() === true)" },
            "name": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 16" },
            "lastSeen": { ".validate": "newData.isNumber() && newData.val() > 0" },
            "isNpc": { ".validate": "newData.isBoolean()" },
            "$other": { ".validate": false }
          }
        },
        "secrets": {
          ".read": "auth != null && root.child('transmit4pRoomsV0').child($code).child('meta').child('hostUid').val() === auth.uid",
          ".write": "auth != null && root.child('transmit4pRoomsV0').child($code).child('meta').child('hostUid').val() === auth.uid",
          "$other": { ".validate": true }
        },
        "private": {
          ".read": "auth != null && root.child('transmit4pRoomsV0').child($code).child('meta').child('hostUid').val() === auth.uid",
          "$uid": {
            ".read": "auth != null && (auth.uid === $uid || root.child('transmit4pRoomsV0').child($code).child('meta').child('hostUid').val() === auth.uid)",
            ".write": "auth != null && (auth.uid === $uid || root.child('transmit4pRoomsV0').child($code).child('meta').child('hostUid').val() === auth.uid)",
            "$other": { ".validate": true }
          }
        },
        "game": {
          ".read": "auth != null && root.child('transmit4pRoomsV0').child($code).child('meta').exists()",
          ".write": "auth != null && root.child('transmit4pRoomsV0').child($code).child('meta').child('hostUid').val() === auth.uid",
          "$other": { ".validate": true }
        },
        "reveal": {
          ".read": "auth != null && root.child('transmit4pRoomsV0').child($code).child('meta').child('phase').val() === 'ended'",
          ".write": "auth != null && root.child('transmit4pRoomsV0').child($code).child('meta').child('hostUid').val() === auth.uid && root.child('transmit4pRoomsV0').child($code).child('meta').child('phase').val() === 'ended'",
          "$other": { ".validate": true }
        },
        "$other": { ".validate": false }
      }
    }
  }
}
