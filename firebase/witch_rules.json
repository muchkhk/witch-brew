{
  "rules": {
    ".read": false,
    ".write": false,

    "roomsV2": {
      "$code": {
        "meta": {
          ".read": "auth != null && $code.matches(/^[ABCDEFGHJKLMNPQRSTUVWXYZ23456789]{6}$/)",
          ".write": "auth != null && $code.matches(/^[ABCDEFGHJKLMNPQRSTUVWXYZ23456789]{6}$/) && ((!data.exists() && newData.child('host').val() === auth.uid) || data.child('host').val() === auth.uid)",
          ".validate": "newData.hasChildren(['host','phase','createdAt'])",
          "host": { ".validate": "newData.isString() && newData.val().length <= 128 && (!data.exists() || newData.val() === data.val())" },
          "phase": {
            ".write": "auth != null && (root.child('roomsV2').child($code).child('seats').child('0').child('uid').val() === auth.uid || root.child('roomsV2').child($code).child('seats').child('1').child('uid').val() === auth.uid || root.child('roomsV2').child($code).child('seats').child('2').child('uid').val() === auth.uid || root.child('roomsV2').child($code).child('seats').child('3').child('uid').val() === auth.uid)",
            ".validate": "newData.isString() && (newData.val() === 'lobby' || newData.val() === 'playing' || newData.val() === 'ended')"
          },
          "createdAt": { ".validate": "newData.isNumber()" },
          "$other": { ".validate": false }
        },

        "seats": {
          ".read": "auth != null && $code.matches(/^[ABCDEFGHJKLMNPQRSTUVWXYZ23456789]{6}$/)",
          ".write": "auth != null && root.child('roomsV2').child($code).child('meta').child('host').val() === auth.uid",
          "$s": {
            ".write": "auth != null && $s.matches(/^[0-3]$/) && ((!data.exists() && newData.child('uid').val() === auth.uid) || data.child('uid').val() === auth.uid)",
            ".validate": "$s.matches(/^[0-3]$/) && newData.hasChildren(['uid','name','lastSeen','online'])",
            "uid": { ".validate": "newData.isString() && newData.val().length <= 128 && (newData.val() === auth.uid || root.child('roomsV2').child($code).child('meta').child('host').val() === auth.uid)" },
            "name": { ".validate": "newData.isString() && newData.val().length <= 24" },
            "lastSeen": { ".validate": "newData.isNumber()" },
            "online": { ".validate": "newData.isBoolean()" },
            "$other": { ".validate": false }
          }
        },

        "privateRecipes": {
          ".read": "auth != null && root.child('roomsV2').child($code).child('meta').child('host').val() === auth.uid",
          ".write": "auth != null && root.child('roomsV2').child($code).child('meta').child('host').val() === auth.uid",
          "$uid": {
            ".read": "auth != null && $uid === auth.uid",
            ".validate": "newData.hasChildren(['0','1','2'])",
            "$i": {
              ".validate": "$i.matches(/^[0-2]$/) && newData.isString() && newData.val().matches(/^(pair_満星|pair_火霜|pair_影蛇|pair_満火|pair_星影|pair_霜蛇|cnt2_満火|cnt2_影星|cnt2_霜蛇|cnt2_満霜|solo_星|solo_霜|solo_満|solo_火|abs2_影蛇|abs2_火星|abs_影|abs_蛇|H_火2蛇無|H_影2満無|H_星2霜無|H_霜2影無|H_満2星無|H_蛇2火無)$/)"
            }
          }
        },

        "game": {
          ".read": "auth != null && $code.matches(/^[ABCDEFGHJKLMNPQRSTUVWXYZ23456789]{6}$/)",
          ".write": "auth != null && $code.matches(/^[ABCDEFGHJKLMNPQRSTUVWXYZ23456789]{6}$/) && ((!data.exists() && root.child('roomsV2').child($code).child('meta').child('host').val() === auth.uid) || (data.exists() && (root.child('roomsV2').child($code).child('seats').child('0').child('uid').val() === auth.uid || root.child('roomsV2').child($code).child('seats').child('1').child('uid').val() === auth.uid || root.child('roomsV2').child($code).child('seats').child('2').child('uid').val() === auth.uid || root.child('roomsV2').child($code).child('seats').child('3').child('uid').val() === auth.uid)))",
          ".validate": "newData.hasChildren(['n','rounds','round','cutter','teamTotal','advanced','phase','band','chooseIdx'])",
          "n": { ".validate": "newData.isNumber() && newData.val() % 1 === 0 && newData.val() >= 3 && newData.val() <= 4" },
          "rounds": { ".validate": "newData.isNumber() && newData.val() % 1 === 0 && newData.val() >= 6 && newData.val() <= 12" },
          "round": { ".validate": "newData.isNumber() && newData.val() % 1 === 0 && newData.val() >= 1 && newData.val() <= 12" },
          "cutter": { ".validate": "newData.isNumber() && newData.val() % 1 === 0 && newData.val() >= 0 && newData.val() <= 3" },
          "teamTotal": { ".validate": "newData.isNumber() && newData.val() >= -1000 && newData.val() <= 10000" },
          "advanced": { ".validate": "newData.isBoolean()" },
          "phase": { ".validate": "newData.isString() && (newData.val() === 'cut' || newData.val() === 'choose' || newData.val() === 'await_score' || newData.val() === 'score' || newData.val() === 'end')" },
          "chooseIdx": { ".validate": "newData.isNumber() && newData.val() % 1 === 0 && newData.val() >= 0 && newData.val() <= 3" },
          "band": {
            "$i": { ".validate": "$i.matches(/^([0-9]|1[01])$/) && newData.isNumber() && newData.val() % 1 === 0 && newData.val() >= 0 && newData.val() <= 5" }
          },
          "cuts": {
            "$i": { ".validate": "$i.matches(/^[0-2]$/) && newData.isNumber() && newData.val() % 1 === 0 && newData.val() >= 1 && newData.val() <= 11" }
          },
          "assign": {
            "$pi": { ".validate": "$pi.matches(/^[0-3]$/) && newData.isNumber() && newData.val() % 1 === 0 && newData.val() >= 0 && newData.val() <= 3" }
          },
          "roundEval": {
            ".validate": "newData.hasChildren(['roundScore','omni','rational','pct','cutPct'])",
            "roundScore": { ".validate": "newData.isNumber() && newData.val() >= -100 && newData.val() <= 100" },
            "omni": { ".validate": "newData.isNumber() && newData.val() >= -100 && newData.val() <= 100" },
            "rational": { ".validate": "newData.isNumber() && newData.val() >= -100 && newData.val() <= 100" },
            "pct": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" },
            "cutPct": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" },
            "$other": { ".validate": false }
          },
          "history": {
            "$h": {
              ".validate": "$h.matches(/^([0-9]|1[01])$/) && newData.hasChildren(['round','cutter','contents','roundScore','omni','rational','pct','cutPct','band','cuts','piles','owners'])",
              "round": { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 12" },
              "cutter": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3" },
              "roundScore": { ".validate": "newData.isNumber() && newData.val() >= -200 && newData.val() <= 200" },
              "omni": { ".validate": "newData.isNumber() && newData.val() >= -200 && newData.val() <= 200" },
              "rational": { ".validate": "newData.isNumber() && newData.val() >= -200 && newData.val() <= 200" },
              "pct": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" },
              "cutPct": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" },
              "contents": { "$s": { "$i": { ".validate": "$s.matches(/^[0-3]$/) && $i.matches(/^([0-9]|1[01])$/) && newData.isNumber() && newData.val() >= 0 && newData.val() <= 5" } } },
              "band": { "$i": { ".validate": "$i.matches(/^([0-9]|1[01])$/) && newData.isNumber() && newData.val() >= 0 && newData.val() <= 5" } },
              "cuts": { "$i": { ".validate": "$i.matches(/^[0-2]$/) && newData.isNumber() && newData.val() >= 1 && newData.val() <= 11" } },
              "piles": { "$pi": { "$i": { ".validate": "$pi.matches(/^[0-3]$/) && $i.matches(/^([0-9]|1[01])$/) && newData.isNumber() && newData.val() >= 0 && newData.val() <= 5" } } },
              "owners": { "$pi": { ".validate": "$pi.matches(/^[0-3]$/) && newData.isNumber() && newData.val() >= 0 && newData.val() <= 3" } },
              "$other": { ".validate": false }
            }
          },
          "$other": { ".validate": false }
        },

        "reveal": {
          ".read": "auth != null && $code.matches(/^[ABCDEFGHJKLMNPQRSTUVWXYZ23456789]{6}$/)",
          ".write": "auth != null && root.child('roomsV2').child($code).child('meta').child('host').val() === auth.uid && root.child('roomsV2').child($code).child('game').child('phase').val() === 'end'",
          "$s": {
            ".validate": "$s.matches(/^[0-3]$/) && newData.hasChildren(['0','1','2'])",
            "$i": {
              ".validate": "$i.matches(/^[0-2]$/) && newData.isString() && newData.val().matches(/^(pair_満星|pair_火霜|pair_影蛇|pair_満火|pair_星影|pair_霜蛇|cnt2_満火|cnt2_影星|cnt2_霜蛇|cnt2_満霜|solo_星|solo_霜|solo_満|solo_火|abs2_影蛇|abs2_火星|abs_影|abs_蛇|H_火2蛇無|H_影2満無|H_星2霜無|H_霜2影無|H_満2星無|H_蛇2火無)$/)"
            }
          }
        },

        "$other": { ".validate": false }
      }
    }
  }
}
