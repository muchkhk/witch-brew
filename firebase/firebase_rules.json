{
  "rules": {
    ".read": false, ".write": false,
    "rooms": {
      "$code": {
        ".read": "$code.matches(/^[A-Z0-9]{4}$/)",
        ".write": "$code.matches(/^[A-Z0-9]{4}$/)",
        "meta": { ".validate": "newData.hasChildren(['host','phase','n'])" },
        "seats": { "$s": { ".validate": "$s.matches(/^[0-5]$/)" } },
        "priv":  { "$s": { ".validate": "$s.matches(/^[0-5]$/)" } },
        "money": { "$s": { ".validate": "$s.matches(/^[0-5]$/) && newData.isNumber()" } },
        "hist":  { "$r": { ".validate": "$r.matches(/^[0-9]{1,2}$/)" } },
        "game":  { ".validate": "newData.hasChildren(['round','phase'])" },
        "reveal": {},
        "$other": { ".validate": false }
      }
    }
  }
}
